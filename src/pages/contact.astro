---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="container">
    <div class="header">
      <h1>Get in Touch</h1>
      <p>Ready to start your musical journey? Let's talk.</p>
    </div>

    <div class="contact-grid">
      <div class="contact-info">
        <h2>Studio Information</h2>
        <p>Please fill out the form, and I will get back to you to discuss lesson availability, pricing, and schedule a trial session.</p>

        <div class="info-block">
          <h3>📍 Location</h3>
          <p>Serving the Fullerton area</p>
        </div>

        <div class="info-block">
          <h3>📧 Email</h3>
          <p>lessons@pianofunstudio.com</p>
        </div>

        <div class="info-block">
          <h3>🎹 Studio Hours</h3>
          <p>Monday - Friday: 3:00 PM - 8:00 PM</p>
          <p>Saturday: 9:00 AM - 1:00 PM</p>
        </div>
      </div>

      <div class="form-card">
        <form class="contact-form">
          <div class="input-group">
            <label for="name">Parent or Student Name</label>
            <input type="text" id="name" name="name" required placeholder="Jane Doe" />
          </div>

          <div class="input-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" required placeholder="jane@example.com" />
          </div>

          <div class="input-group">
            <label for="age">Student Age / Level</label>
            <input type="text" id="age" name="age" placeholder="e.g., 6 years old, Beginner" />
          </div>

          <div class="input-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" required placeholder="Tell me a bit about your musical goals..."></textarea>
          </div>

          <button type="submit" class="submit-btn">Send Message</button>
        </form>
      </div>
    </div>
  </main>
</Layout>

<style>
  :root {
    --primary: #2c3e50;
    --accent: #d35400;
    --text-color: #333;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .header h1 {
    font-size: 3rem;
    color: var(--primary);
    margin-bottom: 0.5rem;
  }

  .header p {
    font-size: 1.2rem;
    color: #666;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-info h2 {
    color: var(--primary);
    margin-top: 0;
  }

  .info-block {
    margin-top: 2rem;
    padding-left: 1rem;
    border-left: 3px solid #ddd;
  }

  .info-block h3 {
    margin-bottom: 0.5rem;
    color: var(--primary);
    font-size: 1.1rem;
  }

  .info-block p {
    margin: 0;
    color: #555;
    line-height: 1.6;
  }

  .form-card {
    background: white;
    padding: 2.5rem;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
  }

  .input-group {
    margin-bottom: 1.5rem;
  }

  .input-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 600;
    color: var(--primary);
  }

  .input-group input,
  .input-group textarea {
    width: 100%;
    padding: 0.8rem;
    border: 2px solid #eee;
    border-radius: 8px;
    font-size: 1rem;
    font-family: inherit;
    transition: border-color 0.3s ease;
    box-sizing: border-box;
  }

  .input-group input:focus,
  .input-group textarea:focus {
    outline: none;
    border-color: var(--accent);
  }

  .submit-btn {
    width: 100%;
    background-color: var(--primary);
    color: white;
    padding: 1rem;
    border: none;
    border-radius: 8px;
    font-size: 1.1rem;
    font-weight: bold;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.1s ease;
  }

  .submit-btn:hover {
    background-color: #1a252f;
  }

  .submit-btn:active {
    transform: translateY(2px);
  }
</style>