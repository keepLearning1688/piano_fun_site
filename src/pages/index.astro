---
import { createClient } from '@supabase/supabase-js'
const supabase = createClient(import.meta.env.SUPABASE_URL, import.meta.env.SUPABASE_ANON_KEY)

// Fetch awards from your database
const { data: awards } = await supabase.from('awards').select('*')
---

<html>
  <body>
    <h1>Student Awards</h1>
    <div class="grid">
      {awards?.map((award) => (
        <div class="card">
          <img src={award.photo_url} alt={award.student_name} width="200"/>
          <h3>{award.student_name}</h3>
          <p>{award.award_title} ({award.year})</p>
        </div>
      ))}
    </div>
  </body>
</html>