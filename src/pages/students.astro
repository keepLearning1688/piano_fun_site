---
// src/pages/students.astro
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="container">
    <div class="header">
      <h1>Student Spotlight</h1>
      <p>Celebrating the hard work, dedication, and musical milestones of our studio family.</p>
    </div>

    <div class="students-grid">

      <!-- Student Card 1 -->
      <div class="student-card">
        <div class="card-header">
          <div class="student-photo">
            <!-- Replace with an actual image tag later: <img src="/images/julia.jpg" alt="Julia" /> -->
            <span>JS</span>
          </div>
          <div class="name-container">
            <h2>Julia S.</h2>
            <span class="age-level">Age 12 • Intermediate</span>
          </div>
        </div>

        <div class="award-badge">
          🏆 First Place, Spring Recital
        </div>

        <p class="student-bio">
          Julia worked incredibly hard this year to master her first Chopin Nocturne. Her dedication to practicing phrasing and dynamics truly paid off during her stunning recital performance!
        </p>
      </div>

      <!-- Student Card 2 -->
      <div class="student-card">
        <div class="card-header">
          <div class="student-photo">
            <span>ML</span>
          </div>
          <div class="name-container">
            <h2>Marcus L.</h2>
            <span class="age-level">Age 8 • Beginner</span>
          </div>
        </div>

        <div class="award-badge">
          🌟 100 Days of Practice
        </div>

        <p class="student-bio">
          Marcus achieved the ultimate consistency award by practicing 100 days in a row! He just graduated to his Level 2 books and is currently learning to compose his own superhero themes.
        </p>
      </div>

      <!-- Student Card 3 -->
      <div class="student-card">
        <div class="card-header">
          <div class="student-photo">
            <span>ET</span>
          </div>
          <div class="name-container">
            <h2>Emma T.</h2>
            <span class="age-level">Age 16 • Advanced</span>
          </div>
        </div>

        <div class="award-badge">
          🎓 Passed CM Level 8 Honors
        </div>

        <p class="student-bio">
          Emma passed her Certificate of Merit Level 8 exam with Honors, scoring a 98% on her music theory test. She is currently preparing audition pieces for college music programs.
        </p>
      </div>

    </div>
  </main>
</Layout>

<style>
  :root {
    --primary: #2c3e50;
    --accent: #d35400;
    --primary-container: #ffdbcc;
    --on-primary-container: #4a1900;
    --text-color: #333;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .header h1 {
    font-size: 3rem;
    color: var(--primary);
    margin-bottom: 0.5rem;
  }

  .header p {
    font-size: 1.2rem;
    color: #666;
  }

  .students-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  /* Once the screen is tablet sized or larger, show 2 cards side-by-side */
  @media (min-width: 768px) {
    .students-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* The Material Design Card */
  .student-card {
    background: white;
    padding: 2rem;
    border-radius: 24px; /* Deep rounded corners for Pixel feel */
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    transition: transform 0.3s cubic-bezier(0.2, 0, 0, 1), box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .student-card:hover {
    transform: translateY(-4px); /* Slight lift on hover */
    box-shadow: 0 12px 32px rgba(0,0,0,0.1);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  /* The Avatar Circle */
  .student-photo {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background-color: #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    font-weight: bold;
    color: #888;
    flex-shrink: 0;
    overflow: hidden; /* Keeps real images perfectly round */
  }

  /* If you add an <img> inside the photo div, this ensures it fits */
  .student-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .name-container h2 {
    margin: 0 0 0.2rem 0;
    color: var(--primary);
    font-size: 1.5rem;
  }

  .age-level {
    font-size: 0.9rem;
    color: #666;
    font-weight: 500;
  }

  /* The Pixel-style Pill Badge */
  .award-badge {
    background-color: var(--primary-container);
    color: var(--on-primary-container);
    padding: 8px 16px;
    border-radius: 100px;
    font-size: 0.95rem;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    align-self: flex-start; /* Keeps it from stretching */
    margin-bottom: 1.5rem;
  }

  .student-bio {
    line-height: 1.6;
    color: #555;
    margin: 0;
  }
</style>