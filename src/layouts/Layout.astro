---
// src/layouts/Layout.astro
// UPDATED FOR ASTRO 5+: ViewTransitions is now called ClientRouter
import { ClientRouter } from 'astro:transitions';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Piano Studio</title>
    <!-- The updated tag for smooth page crossfades -->
    <ClientRouter />
  </head>
  <body>
    <!-- Floating, pill-shaped navbar typical of modern Pixel UI -->
    <div class="nav-container">
      <nav class="navbar">
        <div class="nav-brand">
          <a href="/">🎹 Studio</a>
        </div>
        <div class="nav-links">
          <a href="/">About</a>
          <a href="/contact">Contact</a>
        </div>
      </nav>
    </div>

    <!-- The main content wrapped in an animated fade-in container -->
    <div class="page-content" transition:animate="fade">
      <slot />
    </div>

    <footer class="footer">
      <p>© 2026 Fun Piano Studio. All rights reserved.</p>
    </footer>
  </body>
</html>

<style>
  /* Material You / Pixel UI Color Palette & Spacing */
  :root {
    --surface: #fdfbf7;
    --surface-container: #ffffff;
    --on-surface: #1f1f1f;
    --primary: #d35400;
    --primary-container: #ffdbcc;
    --on-primary-container: #4a1900;
    --nav-bg: rgba(255, 255, 255, 0.85);
  }

  body {
    margin: 0;
    background-color: var(--surface);
    color: var(--on-surface);
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  /* The Floating Navbar Container */
  .nav-container {
    position: sticky;
    top: 16px;
    z-index: 100;
    padding: 0 16px;
    display: flex;
    justify-content: center;
  }

  /* The actual frosted glass pill */
  .navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: var(--nav-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    padding: 8px 16px;
    border-radius: 100px;
    width: 100%;
    max-width: 960px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.4);
  }

  .nav-brand a {
    color: var(--on-surface);
    text-decoration: none;
    font-size: 1.2rem;
    font-weight: 700;
    padding: 8px 16px;
    display: inline-block;
    border-radius: 100px;
    transition: transform 0.2s cubic-bezier(0.2, 0, 0, 1);
  }

  .nav-brand a:active {
    transform: scale(0.92);
  }

  .nav-links {
    display: flex;
    gap: 4px;
  }

  .nav-links a {
    color: var(--on-surface);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 600;
    padding: 10px 20px;
    border-radius: 100px;
    transition: all 0.3s cubic-bezier(0.2, 0, 0, 1);
  }

  .nav-links a:hover {
    background-color: var(--primary-container);
    color: var(--on-primary-container);
  }

  .nav-links a:active {
    transform: scale(0.92);
    background-color: var(--primary);
    color: white;
  }

  .page-content {
    flex: 1;
    animation: slideUpFade 0.7s cubic-bezier(0.2, 0, 0, 1);
    padding-top: 1rem;
  }

  @keyframes slideUpFade {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .footer {
    text-align: center;
    padding: 2rem;
    color: #888;
    margin-top: auto;
    font-size: 0.9rem;
  }
</style>