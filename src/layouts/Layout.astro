---
// src/layouts/Layout.astro
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Piano Studio</title>
  </head>
  <body>
    <!-- THE GLOBAL NAVIGATION BAR -->
    <nav class="navbar">
      <div class="nav-brand">
        <a href="/">🎹 Fun Piano Studio</a>
      </div>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/about">About Me</a>
        <a href="/contact">Contact</a>
      </div>
    </nav>

    <!-- THE PAGE CONTENT GOES HERE -->
    <slot />

    <!-- A GLOBAL FOOTER (Optional) -->
    <footer class="footer">
      <p>© 2026 Fun Piano Studio. All rights reserved.</p>
    </footer>
  </body>
</html>

<style>
  /* Basic styling for the Nav Bar */
  body {
    margin: 0;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  }
  
  .navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2rem;
    background-color: #2c3e50;
    color: white;
  }

  .nav-brand a {
    color: white;
    text-decoration: none;
    font-size: 1.5rem;
    font-weight: bold;
  }

  .nav-links a {
    color: white;
    text-decoration: none;
    margin-left: 2rem;
    font-size: 1.1rem;
    transition: color 0.3s;
  }

  .nav-links a:hover {
    color: #d35400; /* The orange accent color */
  }

  .footer {
    text-align: center;
    padding: 2rem;
    background-color: #f1f1f1;
    color: #666;
    margin-top: 4rem;
  }
</style>